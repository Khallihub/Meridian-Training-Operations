# Copy this to .env and fill in values before running outside Docker

DATABASE_URL=postgresql+asyncpg://meridian:meridian@db:5432/meridian
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

PAYMENT_SIGNATURE_SECRET=change-me-payment-secret

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RECORDINGS=session-recordings
MINIO_USE_SSL=false
PRESIGNED_URL_EXPIRE_SECONDS=3600

EXPORTS_DIR=/app/exports
UPLOADS_DIR=/app/uploads

APP_ENV=production
LOG_LEVEL=INFO
